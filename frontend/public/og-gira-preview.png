<svg width="1200" height="630" viewBox="0 0 1200 630" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%"   stop-color="#0f0720"/>
      <stop offset="100%" stop-color="#1a0a2e"/>
    </linearGradient>
    <linearGradient id="glow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%"   stop-color="#d4af37" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="#d4af37" stop-opacity="0"/>
    </linearGradient>
  </defs>

  <!-- Fundo -->
  <rect width="1200" height="630" fill="url(#bg)"/>

  <!-- Borda dourada sutil -->
  <rect x="24" y="24" width="1152" height="582" rx="20" fill="none" stroke="#d4af37" stroke-width="1.5" stroke-opacity="0.3"/>

  <!-- Glow central -->
  <ellipse cx="600" cy="315" rx="400" ry="200" fill="url(#glow)"/>

  <!-- Símbolo central -->
  <text x="600" y="220" text-anchor="middle" font-family="Georgia, serif" font-size="72" fill="#d4af37" opacity="0.9">☽✦☾</text>

  <!-- Nome do app -->
  <text x="600" y="310" text-anchor="middle" font-family="Georgia, serif" font-size="56" fill="#d4af37" letter-spacing="8">AxeFlow</text>

  <!-- Subtítulo -->
  <text x="600" y="375" text-anchor="middle" font-family="Arial, sans-serif" font-size="22" fill="rgba(255,255,255,0.5)" letter-spacing="4">GESTÃO DE GIRAS E INSCRIÇÕES</text>

  <!-- Linha divisória -->
  <line x1="440" y1="410" x2="760" y2="410" stroke="#d4af37" stroke-width="1" stroke-opacity="0.4"/>

  <!-- CTA -->
  <text x="600" y="460" text-anchor="middle" font-family="Arial, sans-serif" font-size="24" fill="rgba(255,255,255,0.7)">Clique para se inscrever na gira</text>

  <!-- URL -->
  <text x="600" y="570" text-anchor="middle" font-family="Arial, sans-serif" font-size="18" fill="rgba(255,255,255,0.25)">axeflow.vercel.app</text>
</svg>
